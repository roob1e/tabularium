{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tabularium Сервер",
  "version": "1.0.0",
  "identifier": "com.assxmblxr.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tabularium Сервер",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": ["pg18_setup.exe", "server.jar", "application.yml"]
  }
}